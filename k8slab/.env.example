# platform-zero — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env
#   vim .env
#   make up

# Prerequisites on your local machine:
#   brew install ansible kubectl helm
#   SSH key with access to the target machine

# ── Git identity (used by make activate to commit to Gitea) ──────────────────
GIT_USER_NAME=          # your name, e.g. "Asutosh Panda" (quote if it contains spaces)
GIT_USER_EMAIL=         # your email, e.g. you@example.com

# ── Target machine ────────────────────────────────────────────────────────────
TARGET_HOST=            # IP or hostname of your VPS / homelab machine
TARGET_USER=            # SSH user on the target (e.g. ubuntu, root, your-user)
SSH_KEY_PATH=~/.ssh/id_ed25519

# SERVER_IP is embedded into the kubeconfig so kubectl works from your Mac.
# Usually the same as TARGET_HOST. If behind Tailscale, use the Tailscale IP.
SERVER_IP=

# ── NodePorts (must be in range 30000-32767) ──────────────────────────────────
ARGOCD_NODEPORT=30080
GITEA_NODEPORT=30300
ARC_NODEPORT=           # leave blank, ARC runner doesn't need external exposure

# ── Gitea ─────────────────────────────────────────────────────────────────────
# GITEA_ADMIN_USER and GITEA_ADMIN_PASSWORD are auto-generated by make bootstrap.
# Leave them blank — bootstrap writes random credentials to .env before installing Gitea.
# Set GITEA_ADMIN_PASSWORD manually only if you want a specific password.
GITEA_ADMIN_USER=
GITEA_ADMIN_PASSWORD=
GITEA_ADMIN_EMAIL=      # your email

REPO_NAME=platform-zero # name of the repo created in Gitea

# ── CI/CD — ARC runner ────────────────────────────────────────────────────────
# GitHub Personal Access Token with scopes: repo, workflow, admin:org (if org repo)
# Used by ARC to register self-hosted runners with your GitHub repo.
GITHUB_PAT=
GITHUB_REPO=            # e.g. 75asu/platform-zero

ARC_RUNNER_SCALE=1      # number of concurrent runner pods

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=   # Cloudflare API token with Tunnel + DNS edit permissions
CLOUDFLARE_DOMAIN=      # domain managed by Cloudflare, e.g. binarysquad.org

# ── Auto-populated by make bootstrap (do not set manually) ───────────────────
GITEA_ADMIN_USER=       # written here automatically (always "admin")
GITEA_ADMIN_PASSWORD=   # written here automatically (random 20-char)
ARGOCD_ADMIN_USER=      # written here automatically (always "admin")
ARGOCD_ADMIN_PASSWORD=  # written here automatically after bootstrap

# Vault — written by bootstrap after `vault operator init`
VAULT_ROOT_TOKEN=       # written here automatically — treat like a root password
VAULT_UNSEAL_KEY=       # written here automatically — required on every Vault restart

# MinIO — written by bootstrap (random, generated once, stored in Vault)
MINIO_ACCESS_KEY=       # written here automatically
MINIO_SECRET_KEY=       # written here automatically

# Grafana — written by bootstrap (random, generated once, stored in Vault)
GRAFANA_ADMIN_PASSWORD= # written here automatically
