# awslab — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env
#   vim .env
#   make up

# ── Target machine ────────────────────────────────────────────────────────────
TARGET_HOST=            # IP or hostname of your homelab machine
TARGET_USER=            # SSH user (e.g. ubuntu, root)
SSH_KEY_PATH=~/.ssh/id_ed25519
