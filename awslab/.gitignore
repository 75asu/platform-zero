# ── Local config ──────────────────────────────────────────────────────────────
# .env lives one level up (platform-zero/.env) and is gitignored there.
# Do not commit credentials or machine-specific overrides.
*.local
.env

# ── Ansible ───────────────────────────────────────────────────────────────────
# Generated from hosts.yaml.tpl by make — contains real IPs and paths.
ansible/inventory/hosts.yaml

# ── Terraform / Terragrunt ────────────────────────────────────────────────────
# Module download caches — large, machine-specific, rebuilt by terragrunt on init.
.terragrunt-cache/
.terraform/

# Lock files in live/ are generated by terragrunt init inside caches.
# The ones in modules/ are committed (they pin provider versions for the module).
terraform/live/**/.terraform.lock.hcl

# ── Lambda build artifacts ─────────────────────────────────────────────────────
# Generated at plan time by archive_file — do not commit.
terraform/modules/lambda/handlers/*.zip

# ── Editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.idea/
.vscode/
